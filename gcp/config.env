# GCP Configuration for Solo Bank Demo
# Edit these values before running setup.sh

# GCP Project
GCP_PROJECT="kagent-bank-demo"
GCP_REGION="us-central1"
GCP_ZONE="us-central1-a"

# GKE Cluster
GKE_CLUSTER="solo-bank-demo"
GKE_MACHINE_TYPE="e2-standard-4"
GKE_NODE_COUNT=3

# Artifact Registry
AR_REPO="solo-bank-demo"

# Domain (must have DNS access to create records)
DOMAIN="bank-demo.maniak.io"

# Subdomains (all under DOMAIN)
# bank-demo.maniak.io        → Docs site (landing page)
# mgmt.bank-demo.maniak.io   → Management UI
# api.bank-demo.maniak.io    → kagent API
# registry.bank-demo.maniak.io → AgentRegistry

# Image prefix (auto-derived)
IMAGE_PREFIX="${GCP_REGION}-docker.pkg.dev/${GCP_PROJECT}/${AR_REPO}"
